# ─────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente — Plante Gestão
# ─────────────────────────────────────────────────────────────────────────

# Banco (PostgreSQL / Neon).
# Em PRODUÇÃO (Netlify, serverless), use a conexão POOLED do Neon (host com "-pooler"):
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Conexão DIRETA do Neon (host sem "-pooler") — usada pelas migrations (prisma migrate).
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Segredo de sessão do Auth.js. Gere com:  npx auth secret   (ou)   openssl rand -base64 32
AUTH_SECRET="troque-este-segredo-em-producao"

# Em dev local pode apontar DATABASE_URL e DIRECT_URL para a mesma conexão (direta).
