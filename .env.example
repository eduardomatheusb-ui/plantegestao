# ─────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente — Plante Gestão
# ─────────────────────────────────────────────────────────────────────────

# Banco (PostgreSQL / Neon).
# Em PRODUÇÃO (Netlify, serverless), use a conexão POOLED do Neon (host com "-pooler"):
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Conexão DIRETA do Neon (host sem "-pooler") — usada pelas migrations (prisma migrate).
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Segredo de sessão do Auth.js. Gere com:  npx auth secret   (ou)   openssl rand -base64 32
AUTH_SECRET="troque-este-segredo-em-producao"

# Agente HTTP para comparacao de graficas.
# Crie a URL/endpoint e o token no fluxo de API do editor do agente.
# Canal de API do agente de graficas: agtch_6a4b04601e1c8191ab348f2ee08b70a6
AGENTE_API_URL="https://..."
AGENTE_API_KEY="..."

# Integração Site da Plante → CRM (webhook de leads).
# Token secreto exigido no header Authorization: Bearer <valor>.
# Gere com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TREM_WEBHOOK_SECRET="troque-por-um-token-forte"

# Agente de Operações — resumo diário automático.
# Segredo que a função agendada do Netlify usa para chamar o app.
# Gere com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TREM_CRON_SECRET="troque-por-um-token-forte"

# Assistente de IA (ata, briefing e o texto do resumo de operações).
# Sem esta chave o sistema continua funcionando: o resumo sai em versão seca,
# com os mesmos números, e os botões "Gerar com IA" avisam que estão desligados.
# Crie em https://console.anthropic.com/  ·  detalhes em docs/IA-ANTHROPIC.md
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-haiku-4-5"

# Envio de e-mail (Resend) — usado pelos alertas e pelo resumo de operações.
RESEND_API_KEY="re_..."
EMAIL_FROM="TREM <nao-responda@seu-dominio.com.br>"

# Em dev local pode apontar DATABASE_URL e DIRECT_URL para a mesma conexão (direta).
