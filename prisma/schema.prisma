// Plante Gestão — schema Prisma (Fases 1–2: Fundação + Cadastros)
// Banco: PostgreSQL. Modelos das fases 3–8 entram via novas migrations.

generator client {
  provider      = "prisma-client-js"
  // "native" para o build/dev; "rhel-openssl-3.0.x" para o runtime serverless do Netlify (AWS Lambda).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // Produção (Netlify): DATABASE_URL = endpoint COM POOL do Neon (host
  // "-pooler" + pgbouncer=true&connection_limit=1) — essencial em serverless.
  // Migrações rodam LOCALMENTE, onde o .env aponta DATABASE_URL para o
  // endpoint DIRETO (sem pool). Por isso não declaramos directUrl: o cliente
  // em produção depende só de DATABASE_URL e não quebra se faltar outra var.
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Fase 1 — Fundação ───────────────────────────

enum Papel {
  SOCIO_DIRETOR
  GESTOR
  OPERADOR
}

/// Nível de acesso de um perfil a um módulo do sistema.
enum NivelAcesso {
  NENHUM // não vê o módulo
  VER // somente leitura
  EDITAR // cria, edita, arquiva
  ADMIN // tudo, incluindo excluir e configurar
}

/// Perfil de acesso PERSONALIZÁVEL pelo administrador (ex.: Criativo, Atendimento, Mídia…).
/// As capacidades por módulo ficam em PerfilCapacidade. `sistema` protege os perfis-base
/// contra exclusão (podem ser editados, não removidos).
model PerfilAcesso {
  id           String   @id @default(cuid())
  nome         String   @unique
  descricao    String?
  sistema      Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  capacidades PerfilCapacidade[]
  usuarios    Usuario[]
}

/// Nível de um perfil em um módulo. `modulo` é uma chave estável (ver lib/permissoes.ts).
model PerfilCapacidade {
  id       String      @id @default(cuid())
  perfilId String
  modulo   String
  nivel    NivelAcesso @default(NENHUM)

  perfil PerfilAcesso @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  @@unique([perfilId, modulo])
}

model Usuario {
  id                String    @id @default(cuid())
  nome              String
  email             String    @unique
  senhaHash         String?
  papel             Papel     @default(OPERADOR)
  perfilId          String?
  responsavelConta  Boolean   @default(false)
  avatarUrl         String?
  ativo             Boolean   @default(true)
  // Convite por e-mail: token de definição de senha (1º acesso / reset).
  conviteToken      String?   @unique
  conviteExpira     DateTime?
  // 2FA (TOTP) — opt-in. recoveryCodes = hashes bcrypt separados por vírgula.
  totpSecret        String?
  totpAtivo         Boolean   @default(false)
  totpRecoveryCodes String?
  // Lembrete de uso do sistema (popup diário): quando a pessoa viu pela última
  // vez, quando abriu a Bíblia e até onde já leu as novidades.
  lembreteVistoEm   DateTime?
  manualLidoEm      DateTime?
  novidadesVistasEm DateTime?
  criadoEm          DateTime  @default(now())
  atualizadoEm      DateTime  @updatedAt

  perfil      PerfilAcesso? @relation(fields: [perfilId], references: [id], onDelete: SetNull)
  logs        Log[]
  colaborador Colaborador?

  projetosResponsavel   Projeto[]                 @relation("ProjetoResponsavel")
  projetosCriados       Projeto[]                 @relation("ProjetoCriadoPor")
  envolvimentos         ProjetoEnvolvido[]
  comentarios           Comentario[]
  anexos                Anexo[]
  apontamentos          Apontamento[]
  jobsResponsavel       Job[]                     @relation("JobResponsavel")
  jobsCriados           Job[]                     @relation("JobCriadoPor")
  jobsEnvolvido         JobEnvolvido[]
  tarefasResponsavel    JobTarefa[]
  propostasResponsavel  Proposta[]                @relation("PropostaResponsavel")
  propostasCriadas      Proposta[]                @relation("PropostaCriadoPor")
  lancamentosCriados    Lancamento[]              @relation("LancamentoCriadoPor")
  midiaResponsavel      MidiaPlano[]              @relation("MidiaResponsavel")
  midiaCriados          MidiaPlano[]              @relation("MidiaCriadoPor")
  producaoCriadas       ProducaoOrdem[]           @relation("ProducaoCriadoPor")
  notificacoes          Notificacao[]             @relation("NotificacaoDestino")
  notificacoesGeradas   Notificacao[]             @relation("NotificacaoAtor")
  osResponsavel         OrdemServico[]            @relation("OsResponsavel")
  osCriadas             OrdemServico[]            @relation("OsCriadoPor")
  chatMensagens         ChatMensagem[]            @relation("ChatAutor")
  chatLeituras          ChatLeitura[]
  notasFiscais          NotaFiscal[]
  leadsResponsavel      Lead[]                    @relation("LeadResponsavel")
  onboardingItens       OnboardingItem[]          @relation("OnboardingResponsavel")
  reembolsosSolicitados Reembolso[]               @relation("ReembolsoSolicitante")
  reembolsosAnalisados  Reembolso[]               @relation("ReembolsoAnalisadoPor")
  compromissosCriados   Compromisso[]             @relation("CompromissoCriadoPor")
  compromissosParticipa CompromissoParticipante[]
  aprovacaoLotesCriados AprovacaoLote[]           @relation("AprovacaoLoteCriadoPor")
  clientesAtendimento   Cliente[]                 @relation("ClienteAtendimento")
  clientesEstrategia    Cliente[]                 @relation("ClienteEstrategia")
  clientesCadastrados   Cliente[]                 @relation("ClienteCriadoPor")
  planejamentosCriados  PlanejamentoPeriodo[]     @relation("PlanejamentoCriadoPor")
  feedbacksCriados      Feedback[]                @relation("FeedbackAutor")
  feedbacksRespondidos  Feedback[]                @relation("FeedbackRespondidoPor")

  @@index([papel])
}

/// Canal interno: a equipe registra erros, dúvidas e sugestões de melhoria.
model Feedback {
  id              String   @id @default(cuid())
  tipo            String   @default("erro") // erro | duvida | sugestao
  titulo          String
  descricao       String?
  pagina          String? // onde aconteceu (tela/URL)
  status          String   @default("aberto") // aberto | em_analise | resolvido
  autorId         String?
  resposta        String?
  respondidoPorId String?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  autor         Usuario? @relation("FeedbackAutor", fields: [autorId], references: [id], onDelete: SetNull)
  respondidoPor Usuario? @relation("FeedbackRespondidoPor", fields: [respondidoPorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([tipo])
}

/// Chat interno: mural "geral" + conversas diretas. Canal = "geral" ou "dm:<idA>:<idB>" (ids ordenados).
model ChatMensagem {
  id        String    @id @default(cuid())
  canal     String
  autorId   String
  autor     Usuario   @relation("ChatAutor", fields: [autorId], references: [id], onDelete: Cascade)
  corpo     String
  criadoEm  DateTime  @default(now())
  editadoEm DateTime?

  @@index([canal, criadoEm])
}

/// Marca até quando cada usuário leu um canal (para contagem de não lidas).
model ChatLeitura {
  usuarioId    String
  canal        String
  ultimaLidaEm DateTime @default(now())
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([usuarioId, canal])
}

/// Status de uma Ordem de Serviço / Fatura emitida ao cliente.
enum OsStatus {
  RASCUNHO
  EMITIDA
  PAGA
  CANCELADA
}

/// Ordem de Serviço — documento de SAÍDA (emitido AO cliente). Base p/ Fatura e Recibo.
model OrdemServico {
  id                 String    @id @default(cuid())
  numero             Int       @unique
  titulo             String
  clienteId          String
  fornecedorId       String? // fornecedor/prestador que executa o serviço (clareza interna)
  projetoId          String?
  responsavelId      String?
  status             OsStatus  @default(RASCUNHO)
  dataEmissao        DateTime  @default(now())
  vencimento         DateTime?
  formaPagamento     String?
  condicoesPagamento String?
  observacao         String?
  valorTotal         Decimal   @default(0) @db.Decimal(14, 2)
  criadoPorId        String?
  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt

  cliente      Cliente            @relation(fields: [clienteId], references: [id])
  fornecedor   Fornecedor?        @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  projeto      Projeto?           @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  responsavel  Usuario?           @relation("OsResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  criadoPor    Usuario?           @relation("OsCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  itens        OrdemServicoItem[]
  lancamentos  Lancamento[]
  notasFiscais NotaFiscal[]

  @@index([clienteId])
  @@index([status])
}

model OrdemServicoItem {
  id         String   @id @default(cuid())
  osId       String
  descricao  String
  quantidade Decimal  @default(1) @db.Decimal(12, 2)
  valorUnit  Decimal  @default(0) @db.Decimal(14, 2)
  valorTotal Decimal  @default(0) @db.Decimal(14, 2)
  ordem      Int      @default(0)
  criadoEm   DateTime @default(now())

  os OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)

  @@index([osId])
}

/// Notificações pessoais: tudo que envolve o usuário (atribuições, comentários, status…).
model Notificacao {
  id           String   @id @default(cuid())
  usuarioId    String
  atorId       String?
  tipo         String
  titulo       String
  descricao    String?
  entidadeTipo String?
  entidadeId   String?
  url          String?
  lida         Boolean  @default(false)
  criadoEm     DateTime @default(now())

  usuario Usuario  @relation("NotificacaoDestino", fields: [usuarioId], references: [id], onDelete: Cascade)
  ator    Usuario? @relation("NotificacaoAtor", fields: [atorId], references: [id], onDelete: SetNull)

  @@index([usuarioId, lida])
  @@index([criadoEm])
}

/// Numeração sequencial por tipo de entidade (PROJETO, JOB, PROPOSTA, MIDIA, LANCAMENTO).
/// O incremento é feito numa transação com lock de linha — ver lib/sequence.ts.
model Sequence {
  tipo   String @id
  ultimo Int    @default(0)
}

/// Ata de reunião — decisões e próximos passos registrados.
model Reuniao {
  id             String   @id @default(cuid())
  titulo         String
  data           DateTime
  clienteId      String?
  participantes  String?
  ata            String? // ata em texto livre, escrita pela equipe (ou colada da IA)
  pauta          String?
  decisoes       String?
  proximosPassos String?
  compromissoId  String?  @unique // reunião de origem na agenda (se criada a partir dela)
  criadoPorId    String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  cliente     Cliente?     @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  compromisso Compromisso? @relation(fields: [compromissoId], references: [id], onDelete: SetNull)

  @@index([data])
}

/// CRM — lead/oportunidade comercial (funil). Vira Cliente ao ganhar.
model Lead {
  id            String    @id @default(cuid())
  nome          String // contato ou empresa
  empresa       String?
  origem        String? // indicação, instagram, site, evento…
  email         String?
  telefone      String?
  valorEstimado Decimal?  @db.Decimal(14, 2)
  etapa         String    @default("novo") // novo|contato|proposta|negociacao|ganho|perdido
  responsavelId String?
  observacao    String?
  motivoPerda   String?
  interesse     String? // material/assunto de interesse (ex.: Guia ECA Digital)
  tags          String[]  @default([]) // lead-site, guia-eca-digital, material-gratuito…
  consentLgpd   Boolean   @default(false) // marcou o aceite (LGPD)
  consentTexto  String? // texto exato do consentimento aceito
  consentEm     DateTime? // quando o consentimento foi dado
  clienteId     String? // preenchido ao converter
  criadoPorId   String?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  responsavel Usuario? @relation("LeadResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  cliente     Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([etapa])
  @@index([email])
  @@index([telefone])
}

/// Anti-brute-force no login: contagem de falhas e bloqueio temporário por e-mail.
model LoginAttempt {
  email        String    @id
  tentativas   Int       @default(0)
  bloqueadoAte DateTime?
  atualizadoEm DateTime  @updatedAt
}

/// Histórico/auditoria reutilizável por qualquer entidade (LGPD Art. 37 análogo).
model Log {
  id           String   @id @default(cuid())
  entidadeTipo String
  entidadeId   String
  usuarioId    String?
  acao         String
  de           String?
  para         String?
  criadoEm     DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([entidadeTipo, entidadeId])
  @@index([criadoEm])
}

// ─────────────────────────── Fase 2 — Cadastros ──────────────────────────

model Cliente {
  id                  String   @id @default(cuid())
  nome                String
  nomeFantasia        String?
  documento           String? // CNPJ/CPF
  inscricaoEstadual   String?
  inscricaoMunicipal  String?
  email               String?
  telefone            String?
  contatoNome         String?
  endereco            String?
  cep                 String?
  condicoesComerciais String?
  status              String   @default("ativo") // ativo|implantacao|pausado|inadimplente|encerrado
  escopo              String? // serviços contratados / escopo mensal
  tomDeVoz            String? // brand kit: tom de voz
  redesSociais        String? // links das redes
  linksUteis          String? // outros links (Drive, brand guide…)
  logoUrl             String? // URL do logo do cliente (portal e visão)
  portalSlug          String?  @unique // link amigável do portal (nome + sufixo)
  lookerEmbedUrl      String? // URL de incorporação do Looker Studio (aba Performance do portal)
  // Estação do Cliente — responsáveis da conta.
  atendimentoId       String? // responsável pelo atendimento
  estrategiaId        String? // responsável pela estratégia
  criadoPorId         String? // quem cadastrou o cliente
  arquivado           Boolean  @default(false)
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  projetos          Projeto[]
  jobs              Job[]
  propostas         Proposta[]
  lancamentos       Lancamento[]
  midiaPlanos       MidiaPlano[]
  producaoOrdens    ProducaoOrdem[]
  ordensServico     OrdemServico[]
  notasFiscais      NotaFiscal[]
  leads             Lead[]
  reunioes          Reuniao[]
  onboarding        OnboardingItem[]
  campanhas         Campanha[]
  contratos         Contrato[]
  reembolsoDespesas ReembolsoDespesa[]
  compromissos      Compromisso[]
  aprovacaoLotes    AprovacaoLote[]
  atendimento       Usuario?              @relation("ClienteAtendimento", fields: [atendimentoId], references: [id], onDelete: SetNull)
  estrategia        Usuario?              @relation("ClienteEstrategia", fields: [estrategiaId], references: [id], onDelete: SetNull)
  criadoPor         Usuario?              @relation("ClienteCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  dossie            ClienteDossie?
  escopoItens       EscopoItem[]
  acessos           ClienteAcesso[]
  planejamentos     PlanejamentoPeriodo[]
  portalToken       String?               @unique // link público do portal do cliente

  @@index([arquivado])
  @@index([nome])
}

/// Contrato de um cliente. Dois tipos:
/// - recorrente: fee mensal (valorMensal) → base do MRR.
/// - pontual: serviço fechado com validade (valorTotal), NÃO entra no MRR.
model Contrato {
  id            String    @id @default(cuid())
  clienteId     String
  tipo          String    @default("recorrente") // recorrente | pontual
  servico       String? // p/ pontual: mídia, identidade visual, site, produção…
  descricao     String?
  valorMensal   Decimal?  @db.Decimal(14, 2) // recorrente
  valorTotal    Decimal?  @db.Decimal(14, 2) // pontual (valor fechado do serviço)
  diaVencimento Int? // dia do mês de cobrança (1-31)
  dataInicio    DateTime
  dataFim       DateTime? // recorrente: null = vigente. pontual: fim da validade.
  reajusteEm    DateTime? // Estação: data prevista do próximo reajuste
  reajusteObs   String? // Estação: índice/percentual/combinado do reajuste
  status        String    @default("ativo") // ativo | suspenso | encerrado
  propostaId    String? // proposta de origem (quando fechado a partir de uma)
  criadoPorId   String?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@index([clienteId])
  @@index([status])
}

// ─────────────────────────── Estação do Cliente ───────────────────────────

/// Dossiê estratégico da conta (memória viva; orienta qualquer entrega).
model ClienteDossie {
  clienteId            String   @id
  apresentacao         String? // apresentação da empresa
  segmento             String? // segmento / área de atuação
  aprovadores          String? // responsáveis e aprovadores do lado do cliente
  objetivosNegocio     String?
  objetivosComunicacao String?
  publicoAlvo          String?
  produtosPrioritarios String?
  diferenciais         String?
  concorrentes         String?
  posicionamento       String?
  canaisAtivos         String?
  restricoes           String? // restrições e cuidados
  datasImportantes     String?
  historicoRelacao     String? // histórico da relação com a Plante
  antesDeProduzir      String? // "o que precisamos saber antes de produzir"
  atualizadoEm         DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

/// Item de escopo contratado (quadro contratado × utilizado × saldo).
model EscopoItem {
  id               String   @id @default(cuid())
  clienteId        String
  rotulo           String // ex.: "Posts", "Horas de captação"
  bucket           String // posts | videos | materiais | campanhas | reunioes | horas_captacao | outro
  quantidadeMensal Int
  unidade          String   @default("un") // un | horas
  ordem            Int      @default(0)
  criadoEm         DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
}

/// Onde estão os acessos do cliente (NUNCA guarda senha — só onde está e quem tem).
model ClienteAcesso {
  id            String   @id @default(cuid())
  clienteId     String
  plataforma    String // ex.: Instagram, Meta Business, Google, site/hospedagem
  identificacao String? // conta/página/usuário (sem credenciais)
  ondeGuardado  String? // ex.: cofre do 1Password, planilha X
  quemTemAcesso String?
  observacao    String?
  criadoEm      DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
}

/// Planejamento mensal da conta.
model PlanejamentoPeriodo {
  id                   String   @id @default(cuid())
  clienteId            String
  ano                  Int
  mes                  Int // 1-12
  objetivoPrincipal    String?
  pilares              String? // pilares de conteúdo
  produtosPrioritarios String?
  datasImportantes     String?
  acoesOnline          String?
  acoesOffline         String?
  producaoAudiovisual  String?
  verbaMidia           Decimal? @db.Decimal(14, 2)
  indicadores          String? // indicadores acompanhados
  status               String   @default("vigente") // rascunho | vigente | encerrado
  criadoPorId          String?
  criadoEm             DateTime @default(now())
  atualizadoEm         DateTime @updatedAt

  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  criadoPor Usuario? @relation("PlanejamentoCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)

  @@unique([clienteId, ano, mes])
  @@index([clienteId])
}

/// Campanha de tráfego pago (Meta, Google, etc.) de um cliente.
model Campanha {
  id           String    @id @default(cuid())
  nome         String
  clienteId    String
  plataforma   String    @default("meta") // meta | google | tiktok | linkedin | outro
  objetivo     String?
  verba        Decimal?  @db.Decimal(14, 2)
  metaLeads    Int? // meta de leads no período (indicador de metas atingidas)
  metaCpl      Decimal?  @db.Decimal(14, 2) // CPL alvo (custo por lead máximo)
  dataInicio   DateTime?
  dataFim      DateTime?
  status       String    @default("ativa") // ativa | pausada | encerrada
  observacao   String?
  criadoPorId  String?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  cliente    Cliente             @relation(fields: [clienteId], references: [id])
  resultados CampanhaResultado[]

  @@index([clienteId])
  @@index([status])
}

/// Resultado de uma campanha num período (lançado manual ou importado).
model CampanhaResultado {
  id         String   @id @default(cuid())
  campanhaId String
  data       DateTime
  investido  Decimal  @default(0) @db.Decimal(14, 2)
  alcance    Int      @default(0)
  cliques    Int      @default(0)
  conversoes Int      @default(0)
  leads      Int      @default(0)
  observacao String?
  criadoEm   DateTime @default(now())

  campanha Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)

  @@index([campanhaId])
}

/// Item do checklist de implantação (onboarding) de um cliente novo.
model OnboardingItem {
  id            String    @id @default(cuid())
  clienteId     String
  titulo        String
  ordem         Int       @default(0)
  concluido     Boolean   @default(false)
  responsavelId String?
  observacao    String?
  concluidoEm   DateTime?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  responsavel Usuario? @relation("OnboardingResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)

  @@index([clienteId])
}

model Colaborador {
  id             String    @id @default(cuid())
  nome           String
  email          String?
  telefone       String?
  funcao         String?
  documento      String? // CPF/CNPJ
  dataNascimento DateTime? // aniversário
  dataAdmissao   DateTime?
  salario        Decimal?  @db.Decimal(12, 2) // sensível — só Administrador
  valorHora      Decimal?  @db.Decimal(12, 2) // sensível — só Administrador
  usuarioId      String?   @unique
  ativo          Boolean   @default(true)
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  usuario     Usuario?     @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  lancamentos Lancamento[]

  @@index([ativo])
}

model Fornecedor {
  id                 String   @id @default(cuid())
  nome               String
  razaoSocial        String?
  documento          String?
  inscricaoMunicipal String?
  contato            String?
  email              String?
  telefone           String?
  endereco           String?
  cep                String?
  arquivado          Boolean  @default(false)
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  lancamentos    Lancamento[]
  producaoOrdens ProducaoOrdem[]
  ordensServico  OrdemServico[]

  @@index([arquivado])
}

model Prestador {
  id           String   @id @default(cuid())
  nome         String
  documento    String?
  servico      String?
  contato      String?
  arquivado    Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  lancamentos Lancamento[]

  @@index([arquivado])
}

enum VeiculoTipo {
  RADIO
  TV
  EXTERIOR
  DIGITAL
  JORNAL
  REVISTA
  OUTRO
}

model Veiculo {
  id                 String      @id @default(cuid())
  nome               String
  tipo               VeiculoTipo
  razaoSocial        String?
  documento          String? // CNPJ
  inscricaoMunicipal String?
  endereco           String?
  cep                String?
  contatoNome        String?
  contatoEmail       String?
  contatoTelefone    String?
  arquivado          Boolean     @default(false)
  criadoEm           DateTime    @default(now())
  atualizadoEm       DateTime    @updatedAt

  programas   Programa[]
  midiaPlanos MidiaPlano[]

  @@index([arquivado])
  @@index([tipo])
}

model Programa {
  id            String   @id @default(cuid())
  veiculoId     String
  nome          String
  formatoPadrao String?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  veiculo Veiculo @relation(fields: [veiculoId], references: [id], onDelete: Cascade)

  @@index([veiculoId])
}

model Praca {
  id   String  @id @default(cuid())
  nome String
  uf   String?

  @@index([nome])
}

model Produto {
  id           String   @id @default(cuid())
  nome         String
  descricao    String?
  valorUnit    Decimal  @default(0) @db.Decimal(12, 2)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  itensProposta PropostaItem[]

  @@index([ativo])
}

enum CategoriaTipo {
  RECEITA
  DESPESA
}

/// Plano de contas em árvore (categoria pode ter pai e filhos).
model Categoria {
  id           String        @id @default(cuid())
  nome         String
  tipo         CategoriaTipo
  paiId        String?
  ativo        Boolean       @default(true)
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  pai         Categoria?   @relation("Plano", fields: [paiId], references: [id], onDelete: SetNull)
  filhos      Categoria[]  @relation("Plano")
  lancamentos Lancamento[]

  @@index([tipo])
  @@index([paiId])
}

model CentroCusto {
  id           String   @id @default(cuid())
  nome         String
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  lancamentos       Lancamento[]
  reembolsoDespesas ReembolsoDespesa[]
}

model ContaBancaria {
  id           String   @id @default(cuid())
  nome         String
  saldoInicial Decimal  @default(0) @db.Decimal(14, 2)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  lancamentos        Lancamento[] @relation("LancamentoConta")
  lancamentosDestino Lancamento[] @relation("LancamentoContaDestino")
}

// ─────────────────────────── Fase 3 — Projetos ───────────────────────────

enum ProjetoStatus {
  SEM_STATUS
  EM_ANDAMENTO
  PAUSADO
  CONCLUIDO
  CANCELADO
}

model Projeto {
  id                 String        @id @default(cuid())
  numero             Int           @unique
  nome               String
  clienteId          String
  responsavelId      String?
  status             ProjetoStatus @default(SEM_STATUS)
  prazoDesejado      DateTime?
  prazoEstimado      DateTime?
  concluidoEm        DateTime? // setado ao entrar em CONCLUIDO
  concluidoForaPrazo Boolean? // carimbado na conclusão (imutável): concluído depois do prazo?
  budget             Decimal?      @db.Decimal(14, 2)
  tempoEstimadoMin   Int?
  briefing           String?
  favorito           Boolean       @default(false)
  arquivado          Boolean       @default(false)
  projetoPaiId       String?
  criadoPorId        String?
  criadoEm           DateTime      @default(now())
  atualizadoEm       DateTime      @updatedAt

  cliente           Cliente            @relation(fields: [clienteId], references: [id])
  responsavel       Usuario?           @relation("ProjetoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  criadoPor         Usuario?           @relation("ProjetoCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  pai               Projeto?           @relation("Subprojetos", fields: [projetoPaiId], references: [id], onDelete: SetNull)
  subprojetos       Projeto[]          @relation("Subprojetos")
  envolvidos        ProjetoEnvolvido[]
  apontamentos      Apontamento[]
  jobs              Job[]
  propostas         Proposta[]
  lancamentos       Lancamento[]
  midiaPlanos       MidiaPlano[]
  producaoOrdens    ProducaoOrdem[]
  ordensServico     OrdemServico[]
  reembolsoDespesas ReembolsoDespesa[]

  @@index([clienteId])
  @@index([status])
  @@index([arquivado])
  @@index([projetoPaiId])
}

model ProjetoEnvolvido {
  projetoId String
  usuarioId String
  criadoEm  DateTime @default(now())

  projeto Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([projetoId, usuarioId])
  @@index([usuarioId])
}

/// Comentário reutilizável por qualquer entidade (entidadeTipo + entidadeId).
model Comentario {
  id           String    @id @default(cuid())
  entidadeTipo String
  entidadeId   String
  autorId      String?
  texto        String
  criadoEm     DateTime  @default(now())
  editadoEm    DateTime?

  autor Usuario? @relation(fields: [autorId], references: [id], onDelete: SetNull)

  @@index([entidadeTipo, entidadeId])
}

/// Anexo reutilizável (por ora, link/URL — ex.: arquivo no Drive).
model Anexo {
  id           String   @id @default(cuid())
  entidadeTipo String
  entidadeId   String
  nome         String
  tipo         String   @default("link") // "link" (url) | "arquivo" (Netlify Blobs)
  url          String? // só quando tipo = link
  blobKey      String? // chave no Netlify Blobs (tipo = arquivo)
  tamanho      Int? // bytes (tipo = arquivo)
  contentType  String? // mime (tipo = arquivo)
  // Flux — versionamento da mídia por rodada de aprovação (só usado em jobs de postagem).
  versao       Int      @default(1) // rodada em que este anexo foi enviado
  atual        Boolean  @default(true) // aparece no preview / na resposta ao cliente
  criadoPorId  String?
  criadoEm     DateTime @default(now())

  criadoPor Usuario? @relation(fields: [criadoPorId], references: [id], onDelete: SetNull)

  @@index([entidadeTipo, entidadeId])
}

/// Apontamento de horas (timesheet) — base do "Tempo" de projetos e jobs.
model Apontamento {
  id        String   @id @default(cuid())
  usuarioId String
  projetoId String?
  jobId     String?
  data      DateTime
  minutos   Int
  descricao String?
  criadoEm  DateTime @default(now())

  usuario Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  projeto Projeto? @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  job     Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([projetoId])
  @@index([jobId])
  @@index([usuarioId])
}

// ─────────────────────────── Fase 4 — Jobs ───────────────────────────

/// Status configurável (colunas do kanban). Gerido por gestor/sócio.
model JobStatus {
  id           String   @id @default(cuid())
  nome         String
  ordem        Int      @default(0)
  cor          String? // hex para o acento da coluna
  isConcluido  Boolean  @default(false) // marca colunas de "concluído" (métrica de prazo)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  jobs Job[]

  @@index([ordem])
}

model Job {
  id                    String    @id @default(cuid())
  numero                Int       @unique
  tipo                  String    @default("outro") // catálogo em lib/jobs/tipos.ts (post_estatico, video, material_grafico…)
  prioridade            String    @default("normal") // baixa | normal | alta | urgente
  titulo                String
  clienteId             String
  projetoId             String?
  responsavelId         String?
  statusId              String
  prazo                 DateTime? // p/ postagem = prazo de CRIAÇÃO da arte
  prazoPostagem         DateTime? // só postagem: quando vai ao ar
  prazoPostagemOriginal DateTime? // 1ª data de postagem planejada (para medir aderência ao calendário)
  remarcacoesPostagem   Int       @default(0) // quantas vezes a data de postagem foi remarcada
  publicadoEm           DateTime? // só postagem: data real em que a peça foi ao ar
  linkPublicado         String? // só postagem: URL do post ao vivo (colada pelo operador)
  recorrenciaFreq       String? // null = não recorrente; "semanal"|"quinzenal"|"mensal" → este job gera cópias
  recorrenciaProxima    DateTime? // próxima data de geração
  bloqueadoPorId        String? // depende de outro job (não pode começar até ele concluir)
  workflowAtivo         Boolean   @default(false) // tarefas em sequência: cada uma só conclui após a anterior
  legenda               String? // só postagem
  formatos              String? // só postagem: chaves separadas por vírgula (instagram_feed, stories…)
  minutosGravados       Int? // vídeos: minutos gravados (alimenta a "casa do cliente")
  briefing              String?
  aprovacaoStatus       String    @default("rascunho") // rascunho | enviado | aprovado | ajustes
  aprovacaoToken        String?   @unique // token do link público de aprovação do cliente
  aprovacaoEm           DateTime? // quando a peça foi enviada para aprovação
  concluidoEm           DateTime? // setado ao entrar em status isConcluido (para "% no prazo")
  concluidoForaPrazo    Boolean? // carimbado na conclusão (imutável): concluído depois do prazo?
  arquivado             Boolean   @default(false)
  criadoPorId           String?
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt

  cliente            Cliente             @relation(fields: [clienteId], references: [id])
  projeto            Projeto?            @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  responsavel        Usuario?            @relation("JobResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  criadoPor          Usuario?            @relation("JobCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  status             JobStatus           @relation(fields: [statusId], references: [id])
  tarefas            JobTarefa[]
  apontamentos       Apontamento[]
  lancamentos        Lancamento[]
  envolvidos         JobEnvolvido[]
  bloqueadoPor       Job?                @relation("JobDependencia", fields: [bloqueadoPorId], references: [id], onDelete: SetNull)
  bloqueia           Job[]               @relation("JobDependencia")
  aprovacaoEventos   AprovacaoEvento[]
  aprovacaoLoteItens AprovacaoLoteItem[]
  reembolsoDespesas  ReembolsoDespesa[]

  @@index([clienteId])
  @@index([projetoId])
  @@index([responsavelId])
  @@index([statusId])
  @@index([arquivado])
}

/// Histórico do fluxo de aprovação de uma peça (envio + respostas do cliente).
model AprovacaoEvento {
  id         String   @id @default(cuid())
  jobId      String
  acao       String // enviado | aprovado | ajustes | reenviado
  autor      String? // nome de quem respondeu (cliente no link público) ou usuário interno
  comentario String?
  criadoEm   DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

/// Flux — rodada de aprovação em lote: agrupa vários jobs de um cliente num único link público.
model AprovacaoLote {
  id          String    @id @default(cuid())
  clienteId   String
  token       String    @unique // 48 hex, mesmo padrão de Job.aprovacaoToken
  titulo      String? // ex.: "Pauta de Julho"
  status      String    @default("aberto") // aberto | encerrado
  criadoPorId String?
  criadoEm    DateTime  @default(now())
  encerradoEm DateTime?

  cliente   Cliente             @relation(fields: [clienteId], references: [id])
  criadoPor Usuario?            @relation("AprovacaoLoteCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  itens     AprovacaoLoteItem[]

  @@index([clienteId])
  @@index([status])
}

model AprovacaoLoteItem {
  loteId       String
  jobId        String
  ordem        Int       @default(0)
  decisao      String? // null | aprovado | ajustes
  comentario   String?
  respondidoEm DateTime?
  autorNome    String?

  lote AprovacaoLote @relation(fields: [loteId], references: [id], onDelete: Cascade)
  job  Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@id([loteId, jobId])
  @@index([jobId])
}

/// Pessoas envolvidas numa postagem/job (além do responsável).
model JobEnvolvido {
  jobId       String
  usuarioId   String
  /// Quando a pessoa marcou que a PARTE DELA acabou (o job segue com outros,
  /// mas sai da pauta dela). Null = ainda na pauta.
  concluidoEm DateTime?
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([jobId, usuarioId])
}

model JobTarefa {
  id            String    @id @default(cuid())
  jobId         String
  descricao     String
  responsavelId String?
  concluida     Boolean   @default(false)
  concluidaEm   DateTime? // quando a etapa foi concluída (para métricas de fluxo)
  ordem         Int       @default(0)
  prazo         DateTime? // prazo próprio da etapa (opcional)
  criadoEm      DateTime  @default(now())

  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  responsavel Usuario? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)

  @@index([jobId])
}

/// Feriado cadastrado — usado no cálculo de prazos em "dias úteis".
model Feriado {
  id       String   @id @default(cuid())
  data     DateTime @unique // dia do feriado (00:00 local)
  nome     String
  criadoEm DateTime @default(now())

  @@index([data])
}

/// Modelo reutilizável de job: tipo + fluxo de tarefas (+ responsáveis e prazos relativos).
model JobTemplate {
  id            String   @id @default(cuid())
  nome          String
  tipo          String   @default("post_estatico")
  prioridade    String   @default("normal")
  responsavelId String? // responsável padrão do job (id de Usuario, sem FK)
  briefing      String?
  criadoPorId   String?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  tarefas JobTemplateTarefa[]
}

model JobTemplateTarefa {
  id                String  @id @default(cuid())
  templateId        String
  descricao         String
  ordem             Int     @default(0)
  responsavelId     String? // id de Usuario (sem FK)
  prazoRelativoDias Int? // prazo = início do job + N dias

  template JobTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// ─────────────────────────── Fase 5 — Propostas ───────────────────────────

enum PropostaStatus {
  EM_ABERTO
  ENVIADA
  APROVADA
  REPROVADA
  EXPIRADA
}

model Proposta {
  id                  String         @id @default(cuid())
  numero              Int            @unique
  versao              Int            @default(1)
  titulo              String
  clienteId           String
  projetoId           String?
  responsavelId       String?
  status              PropostaStatus @default(EM_ABERTO)
  validadeDias        Int            @default(30)
  prazo               DateTime?
  introducao          String?
  consideracoesFinais String?
  valorTotal          Decimal        @default(0) @db.Decimal(14, 2)
  criadoPorId         String?
  criadoEm            DateTime       @default(now())
  atualizadoEm        DateTime       @updatedAt

  cliente     Cliente        @relation(fields: [clienteId], references: [id])
  projeto     Projeto?       @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  responsavel Usuario?       @relation("PropostaResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  criadoPor   Usuario?       @relation("PropostaCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  itens       PropostaItem[]

  @@index([clienteId])
  @@index([status])
}

model PropostaItem {
  id         String   @id @default(cuid())
  propostaId String
  ordem      Int      @default(0)
  produtoId  String?
  nome       String
  descricao  String?
  valorUnit  Decimal  @default(0) @db.Decimal(12, 2)
  quantidade Decimal  @default(1) @db.Decimal(12, 2)
  desconto   Decimal  @default(0) @db.Decimal(12, 2)
  subtotal   Decimal  @default(0) @db.Decimal(14, 2)
  visivel    Boolean  @default(true)
  criadoEm   DateTime @default(now())

  proposta Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  produto  Produto? @relation(fields: [produtoId], references: [id], onDelete: SetNull)

  @@index([propostaId])
}

// ─────────────────────────── Fase 6 — Financeiro ───────────────────────────

enum LancamentoTipo {
  RECEITA
  DESPESA
  TRANSFERENCIA
}

enum LancamentoStatus {
  EM_ABERTO
  QUITADO
}

enum CondicaoPagamento {
  A_VISTA
  PARCELADO
}

model Lancamento {
  id     String         @id @default(cuid())
  numero Int            @unique
  tipo   LancamentoTipo
  titulo String

  // Sacado / Cedente: cliente (receita) ou fornecedor/prestador/colaborador (despesa)
  clienteId    String?
  fornecedorId String?
  prestadorId  String?

  categoriaId    String?
  projetoId      String?
  propostaId     String? // proposta de origem (receita lançada ao fechar o negócio)
  jobId          String?
  osId           String?
  centroCustoId  String?
  colaboradorId  String? // beneficiário do pagamento (despesa) — a quem o valor se destina
  contaId        String? // conta de origem / movimentação
  contaDestinoId String? // somente em transferência

  docNf String?

  dataVencimento  DateTime
  dataCompetencia DateTime
  dataPagamento   DateTime?
  dataFaturamento DateTime?

  valor      Decimal @db.Decimal(14, 2)
  acrescimos Decimal @default(0) @db.Decimal(14, 2)
  descontos  Decimal @default(0) @db.Decimal(14, 2)

  condicao   CondicaoPagamento @default(A_VISTA)
  status     LancamentoStatus  @default(EM_ABERTO)
  observacao String?

  parcelaGrupo String? // id que liga as parcelas de um mesmo lançamento
  parcelaNum   Int? // número desta parcela (1..N)
  parcelaTotal Int? // total de parcelas

  criadoPorId  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  cliente      Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  fornecedor   Fornecedor?    @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  prestador    Prestador?     @relation(fields: [prestadorId], references: [id], onDelete: SetNull)
  categoria    Categoria?     @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  projeto      Projeto?       @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  job          Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  os           OrdemServico?  @relation(fields: [osId], references: [id], onDelete: SetNull)
  centroCusto  CentroCusto?   @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)
  colaborador  Colaborador?   @relation(fields: [colaboradorId], references: [id], onDelete: SetNull)
  conta        ContaBancaria? @relation("LancamentoConta", fields: [contaId], references: [id], onDelete: SetNull)
  contaDestino ContaBancaria? @relation("LancamentoContaDestino", fields: [contaDestinoId], references: [id], onDelete: SetNull)
  criadoPor    Usuario?       @relation("LancamentoCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  notasFiscais NotaFiscal[]
  reembolso    Reembolso?     @relation("ReembolsoLancamento")

  @@index([tipo])
  @@index([status])
  @@index([dataCompetencia])
  @@index([dataVencimento])
  @@index([clienteId])
  @@index([fornecedorId])
}

// ─────────────────────────── Fase 7 — Mídia ───────────────────────────

enum MidiaStatus {
  EM_ABERTO
  ENVIADA
  APROVADA
  REPROVADA
  CANCELADA
}

model MidiaPlano {
  id                    String      @id @default(cuid())
  numero                Int         @unique
  versao                Int         @default(1)
  tipo                  VeiculoTipo
  titulo                String
  clienteId             String
  projetoId             String?
  responsavelId         String?
  veiculoId             String?
  target                String?
  prazo                 DateTime?
  contatoVeiculo        String?
  rede                  String?
  tipoRede              String?
  numOrcamento          String?
  comissaoPct           Decimal     @default(0) @db.Decimal(6, 2)
  honorarios            Decimal     @default(0) @db.Decimal(14, 2)
  bonificacao           Decimal     @default(0) @db.Decimal(14, 2)
  instrucoesFaturamento String?
  vencimento            DateTime?
  formaPagamento        String?
  valorTotal            Decimal     @default(0) @db.Decimal(14, 2)
  status                MidiaStatus @default(EM_ABERTO)
  criadoPorId           String?
  criadoEm              DateTime    @default(now())
  atualizadoEm          DateTime    @updatedAt

  cliente     Cliente      @relation(fields: [clienteId], references: [id])
  projeto     Projeto?     @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  responsavel Usuario?     @relation("MidiaResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  criadoPor   Usuario?     @relation("MidiaCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  veiculo     Veiculo?     @relation(fields: [veiculoId], references: [id], onDelete: SetNull)
  pecas       MidiaPeca[]
  grades      MidiaGrade[]

  @@index([clienteId])
  @@index([status])
  @@index([tipo])
}

model MidiaPeca {
  id       String   @id @default(cuid())
  planoId  String
  codigo   String // letra/código (A, B, ...)
  nome     String
  criadoEm DateTime @default(now())

  plano  MidiaPlano        @relation(fields: [planoId], references: [id], onDelete: Cascade)
  linhas MidiaGradeLinha[]

  @@index([planoId])
}

model MidiaGrade {
  id        String   @id @default(cuid())
  planoId   String
  pracaNome String?
  ano       Int
  mes       Int
  criadoEm  DateTime @default(now())

  plano  MidiaPlano        @relation(fields: [planoId], references: [id], onDelete: Cascade)
  linhas MidiaGradeLinha[]

  @@index([planoId])
}

model MidiaGradeLinha {
  id            String    @id @default(cuid())
  gradeId       String
  pecaId        String?
  programaNome  String?
  formato       String?
  // Mídia externa (por período): produto/local/datas + quantidade total de inserções.
  produto       String?
  local         String?
  periodoInicio DateTime?
  periodoFim    DateTime?
  quantidade    Int       @default(0)
  desconto      Decimal   @default(0) @db.Decimal(12, 2)
  valorInsercao Decimal   @default(0) @db.Decimal(12, 2)
  ordem         Int       @default(0)
  criadoEm      DateTime  @default(now())

  grade     MidiaGrade      @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  peca      MidiaPeca?      @relation(fields: [pecaId], references: [id], onDelete: SetNull)
  insercoes MidiaInsercao[]

  @@index([gradeId])
}

model MidiaInsercao {
  id           String @id @default(cuid())
  gradeLinhaId String
  dia          Int // dia do mês (1..31)
  quantidade   Int

  gradeLinha MidiaGradeLinha @relation(fields: [gradeLinhaId], references: [id], onDelete: Cascade)

  @@unique([gradeLinhaId, dia])
  @@index([gradeLinhaId])
}

// ─────────────────────────── Configuração: dados da empresa (emitente) ───────────────────────────

/// Registro único (id fixo "singleton") com os dados que vão nos documentos.
model Empresa {
  id              String   @id @default("singleton")
  marca           String
  razaoSocial     String
  cnpj            String
  email           String // comercial (propostas)
  emailFinanceiro String // PI / produção
  telefone        String
  cep             String
  endereco        String
  atualizadoEm    DateTime @updatedAt

  // Dados fiscais p/ emissão de NFS-e (preenchidos quando integrar o provedor).
  inscricaoMunicipal        String?
  codigoMunicipioIbge       String? // IBGE do município emissor (Betim = 3106705)
  itemListaServico          String? // LC 116/03 (ex.: 17.06 — propaganda e publicidade)
  codigoTributarioMunicipio String? // código de serviço / CNAE municipal
  aliquotaIss               Decimal? @db.Decimal(6, 4) // ex.: 2.0000 (=2%)
  optanteSimplesNacional    Boolean  @default(true)
  incentivadorCultural      Boolean  @default(false)
  regimeTributario          String? // descrição (ex.: "Simples Nacional")
  urlEmissaoNfse            String? // link do portal onde se emite a NFS-e (botão "Emitir nota")

  metaFaturamentoMensal Decimal? @db.Decimal(14, 2) // meta de receita do mês (indicadores)

  agendaIcsToken String? // token secreto do feed .ics da agenda (assinatura no Google/Apple)

  manualDriveUrl String? // link do Google Drive da Bíblia Operacional (embutido no /manual)
}

// ─────────────────────────── Agenda compartilhada ───────────────────────────

/// Compromisso/evento da agenda compartilhada da agência (reunião, gravação, visita…).
model Compromisso {
  id              String    @id @default(cuid())
  titulo          String
  tipo            String    @default("reuniao") // reuniao|gravacao|visita|prazo|financeiro|outro
  inicio          DateTime
  fim             DateTime?
  diaInteiro      Boolean   @default(false)
  local           String?
  descricao       String?
  recorrenciaDias Int? // null = não se repete; 7/15/30 = repete a cada N dias
  recorrenciaAte  DateTime? // opcional: repete até esta data (senão, indefinidamente)
  emailsExternos  String? // e-mails avulsos (fora do time) a notificar, separados por vírgula
  clienteId       String?
  criadoPorId     String?
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  cliente       Cliente?                  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  criadoPor     Usuario?                  @relation("CompromissoCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  participantes CompromissoParticipante[]
  reuniao       Reuniao?

  @@index([inicio])
}

model CompromissoParticipante {
  compromissoId String
  usuarioId     String
  compromisso   Compromisso @relation(fields: [compromissoId], references: [id], onDelete: Cascade)
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([compromissoId, usuarioId])
  @@index([usuarioId])
}

/// Situação de uma NFS-e junto ao provedor/prefeitura.
enum NfStatus {
  PROCESSANDO
  AUTORIZADA
  ERRO
  CANCELADA
}

/// NFS-e emitida via provedor (Focus NFe). Documento FISCAL — distinto da OS/Fatura (comercial).
model NotaFiscal {
  id                String   @id @default(cuid())
  ref               String   @unique // referência idempotente enviada ao provedor
  osId              String?
  lancamentoId      String?
  clienteId         String
  status            NfStatus @default(PROCESSANDO)
  numero            String? // número da NFS-e autorizada
  codigoVerificacao String?
  valor             Decimal  @db.Decimal(14, 2)
  descricao         String
  urlPdf            String?
  urlXml            String?
  mensagemErro      String?
  criadoPorId       String?
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  os         OrdemServico? @relation(fields: [osId], references: [id], onDelete: SetNull)
  lancamento Lancamento?   @relation(fields: [lancamentoId], references: [id], onDelete: SetNull)
  cliente    Cliente       @relation(fields: [clienteId], references: [id])
  criadoPor  Usuario?      @relation(fields: [criadoPorId], references: [id], onDelete: SetNull)

  @@index([osId])
  @@index([clienteId])
  @@index([status])
}

// ─────────────────────────── Produção (Pedido de Produção) ───────────────────────────

enum ProducaoStatus {
  EM_ABERTO
  ENVIADA
  APROVADA
  REPROVADA
  CANCELADA
}

model ProducaoOrdem {
  id             String         @id @default(cuid())
  numero         Int            @unique
  versao         Int            @default(1)
  titulo         String
  clienteId      String
  projetoId      String?
  fornecedorId   String?
  responsavelId  String?
  dataEntrega    DateTime?
  vencimento     DateTime?
  formaPagamento String?
  comissaoPct    Decimal        @default(0) @db.Decimal(6, 2)
  observacao     String?
  valorTotal     Decimal        @default(0) @db.Decimal(14, 2)
  status         ProducaoStatus @default(EM_ABERTO)
  criadoPorId    String?
  criadoEm       DateTime       @default(now())
  atualizadoEm   DateTime       @updatedAt

  cliente    Cliente        @relation(fields: [clienteId], references: [id])
  projeto    Projeto?       @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  fornecedor Fornecedor?    @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  criadoPor  Usuario?       @relation("ProducaoCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)
  itens      ProducaoItem[]

  @@index([clienteId])
  @@index([status])
}

model ProducaoItem {
  id         String   @id @default(cuid())
  ordemId    String
  ordem      Int      @default(0)
  titulo     String
  quantidade Decimal  @default(1) @db.Decimal(12, 2)
  valorUnit  Decimal  @default(0) @db.Decimal(12, 2)
  valorTotal Decimal  @default(0) @db.Decimal(14, 2)
  criadoEm   DateTime @default(now())

  ordemRef ProducaoOrdem @relation(fields: [ordemId], references: [id], onDelete: Cascade)

  @@index([ordemId])
}

// ─────────────────────────── Central de Reembolsos ───────────────────────────

/// Fluxo de reembolso operacional: colaborador junta despesas do mês num pedido,
/// envia para o financeiro conferir (aprovar/ajustar/reprovar), que programa e paga.
enum ReembolsoStatus {
  RASCUNHO // colaborador ainda montando
  ENVIADO // enviado para análise do financeiro
  PENDENTE_AJUSTE // financeiro pediu correção/comprovante
  APROVADO // validado pelo financeiro
  REPROVADO // recusado
  PROGRAMADO // entrou no lote de pagamento (lançamento gerado)
  PAGO // reembolso realizado
}

model Reembolso {
  id                    String          @id @default(cuid())
  numero                Int             @unique
  solicitanteId         String
  competenciaAno        Int
  competenciaMes        Int // 1..12
  status                ReembolsoStatus @default(RASCUNHO)
  observacaoSolicitante String?
  // Análise do financeiro
  analisadoPorId        String?
  analisadoEm           DateTime?
  parecerFinanceiro     String? // motivo do ajuste/recusa ou observação da análise
  // Pagamento
  dataPrevistaPagamento DateTime? // dia 20 do mês seguinte à competência
  dataPagamento         DateTime?
  lancamentoId          String?         @unique // despesa gerada no financeiro ao programar
  criadoEm              DateTime        @default(now())
  atualizadoEm          DateTime        @updatedAt

  solicitante  Usuario            @relation("ReembolsoSolicitante", fields: [solicitanteId], references: [id])
  analisadoPor Usuario?           @relation("ReembolsoAnalisadoPor", fields: [analisadoPorId], references: [id], onDelete: SetNull)
  lancamento   Lancamento?        @relation("ReembolsoLancamento", fields: [lancamentoId], references: [id], onDelete: SetNull)
  despesas     ReembolsoDespesa[]

  @@index([solicitanteId])
  @@index([status])
  @@index([competenciaAno, competenciaMes])
}

model ReembolsoDespesa {
  id                String   @id @default(cuid())
  reembolsoId       String
  data              DateTime // data em que a despesa ocorreu
  categoria         String // chave: alimentacao|transporte_app|combustivel|estacionamento|pedagio|hospedagem|material|compra_autorizada|deslocamento|viagem|outros
  descricao         String
  valor             Decimal  @db.Decimal(14, 2)
  formaPagamento    String? // pix|dinheiro|cartao_proprio|cartao_empresa|outro
  clienteId         String?
  projetoId         String?
  jobId             String?
  centroCustoId     String?
  repassavelCliente Boolean  @default(false) // despesa que pode ser repassada ao cliente
  autorizadoPor     String? // quem autorizou (obrigatório acima do limite)
  aprovada          Boolean? // avaliação individual do financeiro: null=não avaliada, true/false
  parecerItem       String? // motivo da reprovação do item
  ordem             Int      @default(0)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  reembolso   Reembolso    @relation(fields: [reembolsoId], references: [id], onDelete: Cascade)
  cliente     Cliente?     @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  projeto     Projeto?     @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  job         Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  centroCusto CentroCusto? @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)

  @@index([reembolsoId])
  @@index([clienteId])
}

/// Fluxo de etapas padrão de um TIPO de job — o roteiro que nasce junto com o job.
/// Uma linha por tipo; `etapas` é um JSON com a lista ordenada (ex.: ["Briefing","Edição"]).
/// A linha EXISTIR significa "configurado na tela" — inclusive lista vazia, quando o admin
/// não quer etapa nenhuma. Sem linha, vale o padrão de fábrica (lib/jobs/fluxos.ts).
model TipoJobFluxo {
  id           String   @id @default(cuid())
  tipo         String   @unique
  etapas       String
  atualizadoEm DateTime @updatedAt
}

/// Regra de corresponsável automático de um TIPO de job, por ÁREA.
/// `funcoes` = termos de função separados por vírgula (ex.: "videomaker, audiovisual").
/// Quem tem login ativo e função compatível entra sozinho como corresponsável.
/// Sem linha aqui, vale o padrão de fábrica (lib/jobs/corresponsaveis.ts).
model TipoJobArea {
  id           String   @id @default(cuid())
  tipo         String   @unique
  funcoes      String
  atualizadoEm DateTime @updatedAt

  @@index([tipo])
}
